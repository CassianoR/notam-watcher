{
  "FaaApi": {
    "ApiKey": "",
    "BaseUrl": "https://api.faa.gov/notamapi/v1",
    "FetchIntervalSeconds": 60,
    "PageSize": 100
  },
  "Database": {
    "Path": "notams.db"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
